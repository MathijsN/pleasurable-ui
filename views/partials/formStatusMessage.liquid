<dialog
  id="succes-dialog"
  {% if status == 'succes' %}
    open
  {% endif %}
>
  <h2>Your snapp has been added successfully!</h2>
  <button commandfor="succes-dialog" command="close">OK</button>
</dialog>

<dialog
  id="failure-dialog"
  {% if status == 'upload_failed' %}
    open
  {% endif %}
>
  <h2>Something went wrong, please try again.</h2>
  <button commandfor="succes-dialog" command="close">OK</button>
</dialog>
