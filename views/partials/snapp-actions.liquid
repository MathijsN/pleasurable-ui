{% assign isOwner = oneSnappInfo[0].author.uuid == userUuid %}

<header>
  <a href="/snappmaps/{{ oneSnappInfo[0].snapmap.slug }}" class="go-back-link">
    <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
      <title>Go back to the Snappmap {{ oneSnappInfo[0].snapmap.name }}</title>
      <path fill-rule="evenodd" clip-rule="evenodd" d="M7.6 14L18.8 2.8L16 0L0 16L16 32L18.8 29.2L7.6 18H32V14H7.6Z" fill=""/>
    </svg>
  </a>

  <form action="/snapps/{{snappUuid}}/action" method="POST" class="like-dislike-save-form" data-enhanced="actions">
    {% comment %} Like button {% endcomment %}
    <label class="{% if hasLike == true %}like-active{% endif %} {% if isOwner %}inactive{% endif %} {% if isOwner and likesCount.size > 0 %}heart-inactive{% endif %}">
      {% if isOwner %}
        <button type="button">
        {% else %}
        <button type="submit" name="action" value="like">
      {% endif %}
          <svg viewBox="0 0 26 24" xmlns="http://www.w3.org/2000/svg">
            <title>Like this Snapp</title>
            <path fill-rule="evenodd" clip-rule="evenodd" d="M11.18 22.1801C4.42 16.2001 0 12.1701 0 7.23008C0 3.20008 3.12 0.0800781 7.15 0.0800781C9.36 0.0800781 11.57 2.05608 13 3.74608C14.43 2.05608 16.64 0.0800781 18.85 0.0800781C22.88 0.0800781 26 3.20008 26 7.23008C26 12.1701 21.58 16.2001 14.82 22.1801L13 24.0001L11.18 22.1801Z" fill=""/>
          </svg>
        </button>
      <p class="loading-count">{{ likesCount | size}}</p>
    </label>

    {% comment %} Dislike button {% endcomment %}
    <label class="{% if hasTomato == true %}tomato-active{% endif %} {% if isOwner %}inactive{% endif %} {% if isOwner and tomatoCount.size > 0 %}tomato-inactive{% endif %}">
      {% if isOwner %}
        <button type="button">
        {% else %}
        <button type="submit" name="action" value="tomato">
      {% endif %}
            <svg viewBox="0 0 25 26" xmlns="http://www.w3.org/2000/svg">
              <title>Dislike this Snapp</title>
              <path fill-rule="evenodd" clip-rule="evenodd" d="M13.4058 3.72573C13.8278 3.40698 14.3574 3.0832 14.9917 2.83616C16.1688 2.37764 17.9625 2.5135 19.9376 3.75587C19.9376 3.75587 18.8096 5.11737 17.6308 5.67973C16.5155 6.21178 15.9504 6.26072 15.76 6.27722L15.731 6.27981C16.5271 6.82259 17.2388 7.72723 17.6003 9.21083C17.6003 9.21083 15.8777 9.4264 14.802 9.02689C13.7263 8.62738 12.854 8.08004 12.3625 6.78038C12.3603 6.78742 12.3571 6.80485 12.3522 6.83125L12.3522 6.83129C12.3026 7.09881 12.0823 8.28695 11.0688 8.92738C9.95525 9.63107 8.72583 10.0371 7.50457 9.85011C7.42315 9.83805 7.57996 7.4287 9.69078 6.31298C9.57921 6.34012 8.65537 6.50379 7.36284 6.32203C6.07032 6.14026 4.9354 5.27566 4.1755 4.15994C4.11821 4.07249 6.81705 2.01294 9.80536 3.37894L9.80632 3.37941C9.84083 3.39631 10.7891 3.86081 11.5707 4.42144C11.6169 4.00824 11.72 3.38475 11.9495 2.61703C12.3774 1.18528 13.0928 0.0131043 13.0928 0.0131043L15.0185 0C15.0185 0 14.3365 0.747239 13.8811 2.01939C13.7055 2.50991 13.5413 3.13849 13.4058 3.72573ZM18.3084 6.9616C19.2513 8.72819 19.4199 10.3489 19.4199 10.3489C19.4199 10.3489 18.5626 10.7781 16.6085 10.724C14.9853 10.679 13.6024 10.2901 12.5699 9.48645C11.5462 10.699 10.1054 11.3612 8.39262 11.3612C8.03167 11.3612 7.65263 11.3325 7.27087 11.2728C6.63431 11.176 6.12952 10.6938 6.01584 10.0739C5.93171 9.60646 6.04418 8.67016 6.49922 7.68712C5.60815 7.42629 4.95892 7.22425 4.07841 6.30966C1.74927 8.48954 0 10.6278 0 13.9976C0 20.6252 5.59699 26 12.4997 26C19.403 26 24.9988 20.6255 24.9988 13.9976C24.9988 10.2774 22.9356 7.859 20.1692 5.65591C19.6792 6.14351 19.2513 6.46948 18.3084 6.9616Z" fill=""/>
            </svg>
        </button>
      <p class="loading-count">{{ tomatoCount | size }}</p>
    </label>

    {% comment %} Star button {% endcomment %}
    <label class="{% if hasStar == true %}star-active{% endif %} {% if isOwner %}inactive{% endif %} {% if isOwner and starCount.size > 0 %}star-inactive{% endif %}">
      {% if isOwner %}
        <button type="button">
        {% else %}
        <button type="submit" name="action" value="star">
      {% endif %}
          <svg viewBox="0 0 38 36" xmlns="http://www.w3.org/2000/svg">
            <title>Add this snap to favorites</title>
            <path fill-rule="evenodd" clip-rule="evenodd" d="M18.9474 28.9383L30.6568 36L27.5589 22.6819L37.8947 13.7255L24.2697 12.5564L18.9474 0L13.6251 12.5564L0 13.7255L10.3358 22.6819L7.23789 36L18.9474 28.9383Z" fill=""/>
          </svg>
        </button>
      <p class="loading-count">{{ starCount | size }}</p>
    </label>
  </form>
</header>

{% comment %} Switched dislike to like {% endcomment %}
{% if status == 'switched-to-like' %}
  <section class="action-popup">
    <svg viewBox="0 0 26 24" xmlns="http://www.w3.org/2000/svg" height="30" class="heart-color">
      <path fill-rule="evenodd" clip-rule="evenodd" d="M11.18 22.1801C4.42 16.2001 0 12.1701 0 7.23008C0 3.20008 3.12 0.0800781 7.15 0.0800781C9.36 0.0800781 11.57 2.05608 13 3.74608C14.43 2.05608 16.64 0.0800781 18.85 0.0800781C22.88 0.0800781 26 3.20008 26 7.23008C26 12.1701 21.58 16.2001 14.82 22.1801L13 24.0001L11.18 22.1801Z" fill=""/>
    </svg>
    <h2>YOU SWAPPED TO LIKE!</h2>
    <p>You have swapped from tomato to like</p>
  </section>
{% endif %}

{% comment %} Switched like to dislike {% endcomment %}
{% if status == 'switched-to-tomato' %}
  <section class="action-popup">
    <svg viewBox="0 0 25 26" xmlns="http://www.w3.org/2000/svg" height="30" class="tomato-color">
      <title>Dislike this Snapp</title>
      <path fill-rule="evenodd" clip-rule="evenodd" d="M13.4058 3.72573C13.8278 3.40698 14.3574 3.0832 14.9917 2.83616C16.1688 2.37764 17.9625 2.5135 19.9376 3.75587C19.9376 3.75587 18.8096 5.11737 17.6308 5.67973C16.5155 6.21178 15.9504 6.26072 15.76 6.27722L15.731 6.27981C16.5271 6.82259 17.2388 7.72723 17.6003 9.21083C17.6003 9.21083 15.8777 9.4264 14.802 9.02689C13.7263 8.62738 12.854 8.08004 12.3625 6.78038C12.3603 6.78742 12.3571 6.80485 12.3522 6.83125L12.3522 6.83129C12.3026 7.09881 12.0823 8.28695 11.0688 8.92738C9.95525 9.63107 8.72583 10.0371 7.50457 9.85011C7.42315 9.83805 7.57996 7.4287 9.69078 6.31298C9.57921 6.34012 8.65537 6.50379 7.36284 6.32203C6.07032 6.14026 4.9354 5.27566 4.1755 4.15994C4.11821 4.07249 6.81705 2.01294 9.80536 3.37894L9.80632 3.37941C9.84083 3.39631 10.7891 3.86081 11.5707 4.42144C11.6169 4.00824 11.72 3.38475 11.9495 2.61703C12.3774 1.18528 13.0928 0.0131043 13.0928 0.0131043L15.0185 0C15.0185 0 14.3365 0.747239 13.8811 2.01939C13.7055 2.50991 13.5413 3.13849 13.4058 3.72573ZM18.3084 6.9616C19.2513 8.72819 19.4199 10.3489 19.4199 10.3489C19.4199 10.3489 18.5626 10.7781 16.6085 10.724C14.9853 10.679 13.6024 10.2901 12.5699 9.48645C11.5462 10.699 10.1054 11.3612 8.39262 11.3612C8.03167 11.3612 7.65263 11.3325 7.27087 11.2728C6.63431 11.176 6.12952 10.6938 6.01584 10.0739C5.93171 9.60646 6.04418 8.67016 6.49922 7.68712C5.60815 7.42629 4.95892 7.22425 4.07841 6.30966C1.74927 8.48954 0 10.6278 0 13.9976C0 20.6252 5.59699 26 12.4997 26C19.403 26 24.9988 20.6255 24.9988 13.9976C24.9988 10.2774 22.9356 7.859 20.1692 5.65591C19.6792 6.14351 19.2513 6.46948 18.3084 6.9616Z" fill=""/>
    </svg>
    <h2>YOU SWAPPED TO TOMATO!</h2>
    <p>You have swapped from like to tomato</p>
  </section>
{% endif %}

{% comment %} Likes, dislikes & favorites - loading & succes state {% endcomment %}

<script>
  
  // Stap 1: Submit een formulier / like, dislike of favorite een snapp
  document.addEventListener('submit', async function(event) {

    const form = event.target // Hou in een variabele bij welk formulier dat was
    const actionURL = form.getAttribute("action") // Zet de action van het formulier om in een variabele: (action="/snapps/{snappUuid}/action")
    const buttons = form.querySelectorAll("button[name='action']") // buttons in huidig formulier
    const formData = new URLSearchParams() // Maak de data die we gaan sturen (alleen de action knop)
    const clickedButton = event.submitter // Pak welke knop is geklikt

    // Als dit geen like/dislike/star formulier is, doe niks speciaals
    if (!form.classList.contains('like-dislike-save-form')) {
      return
    }

    // Stap 2: Voorkom de standaard submit van de browser
    event.preventDefault()
    
    // Stap 3: Toon de loading-state en disable alle knoppen 
    // Zet loading state op geklikte knop
    if (clickedButton) {
      clickedButton.classList.add("loading-actions")
    }

    // Disable alle knoppen als de loading state aan staat 
    buttons.forEach(function(btn) {
      btn.disabled = true
    })

    // Voeg alleen de data van de geklikte knop toe aan de body van het formulier
    if (clickedButton) {
      formData.append(clickedButton.name, clickedButton.value)
    }

    // Stap 4: Data fetchen
    // Verstuur naar server
    const response = await fetch(actionURL, {
      method: form.method,
      body: formData
    })

    // Stap 5: Verwerk de data
    // Server geeft HTML terug
    const responseText = await response.text()

    // Stap 6: Voeg data toe aan de DOM
    // Maak nieuwe DOM van die HTML
    const parser = new DOMParser()
    const responseDOM = parser.parseFromString(responseText, 'text/html')
    
    // Zoek het nieuwe formulier in de response
    const newForm = responseDOM.querySelector('.like-dislike-save-form')
    if (!newForm) {
      console.error('No updated form found')
      return
    }

    // Vervang oud formulier met nieuw formulier
    form.replaceWith(newForm)

    // Stap 7a: Haal de loading-state weg en maak de knoppen in het nieuwe formulier klikbaar
    const newButtons = newForm.querySelectorAll("button[name='action']")
    newButtons.forEach(function(btn) {
      btn.disabled = false
      btn.classList.remove("loading-actions")
    })

    // Stap 7b: Animeer de geklikte knop
    const newClickedLabel = newForm.querySelector(`button[value="${clickedButton.value}"]`).closest('label');
    newClickedLabel.classList.add('just-activated');
    newClickedLabel.addEventListener('animationend', function () {
      newClickedLabel.classList.remove('just-activated');
    });
    // Stap 8: Toon de succes-state (pop-up)
    // Zoek naar de pop-up in de response van de URL
    const newPopup = responseDOM.querySelector('.action-popup')
    const existingPopup = document.querySelector('.action-popup')
    
    if (existingPopup) {
      existingPopup.remove()
    }

    if (newPopup) {
      document.body.insertAdjacentElement('afterbegin', newPopup)
    }

    // Stap 9: Haal de succes-state (pop-up) uit de DOM als de animatie over is 
    if (newPopup) {
      newPopup.addEventListener('animationend', function() {
        newPopup.remove()
      })
    }
  })
</script>
