{% render 'partials/head.liquid', title: 'Groups' %}

<ul>
{% for groups in allGroups %}
    {% assign today_date = 'now' | date: '%Y%m%d' %}

    {% for snappmap in groups.snappmap %}
      {% assign target_date = snappmap.snappthis_snapmap_uuid.time_end | date: '%Y%m%d' %}
    {% endfor %}

    {% if target_date > today_date %}
      <li class="group-list-container">
        <a href="/groups/{{ groups.slug }}"><strong>{{ groups.name }}</strong></a>
        <p class="active"><strong>Add your snapp!</strong></p>
      </li>

    {% else %}
      <li class="group-list-container">
        <a href="/groups/{{ groups.slug }}">{{ groups.name }}</a>
        {% if group.users_count == null %}
          <p>{{ groups.users_count }} members</p>
        {% else %}
          <p>No members yet</p>
        {% endif %}
      </li>
    {% endif %}
{% endfor %}
</ul>

{% render 'partials/footer.liquid'%}